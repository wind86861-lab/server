// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLINIC_ADMIN
  PATIENT
  PENDING_CLINIC
}

enum UserStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id           String     @id @default(uuid())
  phone        String     @unique
  email        String?
  passwordHash String
  firstName    String?
  lastName     String?
  role         Role       @default(PATIENT)
  status       UserStatus @default(PENDING)
  isActive     Boolean    @default(true)
  clinicId     String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  diagnosticServices DiagnosticService[] @relation("CreatedBy")
  surgicalServices   SurgicalService[]   @relation("SurgicalCreatedBy")

  appointments Appointment[]
  reviews      Review[]

  @@index([phone])
  @@index([status])
  @@index([role])
}

model ServiceCategory {
  id        String   @id @default(uuid())
  parentId  String?
  level     Int      @default(0)
  nameUz    String
  nameRu    String?
  nameEn    String?
  slug      String   @unique
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ServiceCategory[] @relation("CategoryHierarchy")

  diagnosticServices DiagnosticService[]
  surgicalServices   SurgicalService[]
}

model DiagnosticService {
  id               String  @id @default(uuid())
  nameUz           String
  nameRu           String?
  nameEn           String?
  categoryId       String
  shortDescription String? @db.VarChar(200)
  fullDescription  String? @db.Text

  priceRecommended Int @default(0)
  priceMin         Int @default(0)
  priceMax         Int @default(0)

  durationMinutes Int   @default(30)
  resultTimeHours Float @default(24)

  preparation       String? @db.Text
  contraindications String? @db.Text
  sampleType        String? @db.VarChar(100)

  imageUrl String?
  isActive Boolean @default(true)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  category ServiceCategory @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]             @relation("DiagnosticServiceAppointments")
  clinicLinks  ClinicDiagnosticService[] @relation("DiagnosticServiceClinicLinks")

  @@index([categoryId])
  @@index([isActive])
  @@index([priceRecommended])
}

model SurgicalService {
  id String @id @default(uuid())

  // Basic
  nameUz           String
  nameRu           String?
  nameEn           String?
  categoryId       String
  shortDescription String? @db.VarChar(200)
  fullDescription  String? @db.Text
  imageUrl         String?

  // Pricing & Time
  priceRecommended Int
  priceMin         Int
  priceMax         Int
  durationMinutes  Int  @default(0)
  minDuration      Int?
  maxDuration      Int?
  recoveryDays     Int  @default(0)

  // Anesthesia
  anesthesiaType  AnesthesiaType
  anesthesiaNotes String?        @db.Text

  // Hospitalization
  requiresHospitalization Boolean   @default(true)
  hospitalizationDays     Int?
  roomType                RoomType?
  requiresICU             Boolean   @default(false)
  icuDays                 Int?
  hospitalizationNotes    String?   @db.Text

  // Pre-operation
  requiredTests             Json? // Array of test requirements
  preparationFasting        Boolean @default(false)
  fastingHours              Int?
  preparationMedication     String? @db.Text
  preparationRestrictions   Json? // Array of restrictions
  preparationTimeline       String? @db.Text
  contraindicationsAbsolute Json? // Array
  contraindicationsRelative Json? // Array

  // Operation Details
  complexity            Complexity
  riskLevel             RiskLevel
  minSurgeonExperience  Int        @default(0)
  surgeonQualifications Json? // Array
  surgeonSpecialization String?
  requiredEquipment     Json? // Array of equipment
  operationStages       Json? // Array of stages

  // Post-operation
  postOpImmediate    Json? // monitoring, meds, restrictions
  postOpHome         Json? // home care instructions
  followUpSchedule   Json? // Array of follow-up visits
  recoveryMilestones Json? // Array of milestones

  // Package
  packageIncluded Json? // What's included
  packageExcluded Json? // What's not included (+ prices)

  // Additional
  alternatives Json? // Array of alternatives
  faqs         Json? // Array of FAQs
  successRate  Float?
  videoUrl     String?

  // Status & Meta
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User            @relation("SurgicalCreatedBy", fields: [createdById], references: [id])
  category  ServiceCategory @relation(fields: [categoryId], references: [id])

  appointments Appointment[]           @relation("SurgicalServiceAppointments")
  clinicLinks  ClinicSurgicalService[] @relation("SurgicalServiceClinicLinks")

  @@index([categoryId])
  @@index([isActive])
  @@index([complexity])
  @@index([riskLevel])
}

enum AnesthesiaType {
  LOCAL
  GENERAL
  SPINAL
  SEDATION
}

enum RoomType {
  STANDARD
  COMFORT
  LUX
  VIP
}

enum Complexity {
  SIMPLE
  MEDIUM
  COMPLEX
  ADVANCED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ClinicSource {
  ADMIN_CREATED
  SELF_REGISTERED
}

enum ClinicStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  BLOCKED
  SUSPENDED
  DELETED
}

enum ClinicType {
  GENERAL
  SPECIALIZED
  DIAGNOSTIC
  DENTAL
  MATERNITY
  REHABILITATION
  PHARMACY
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentServiceType {
  DIAGNOSTIC
  SURGICAL
  OTHER
}

model Clinic {
  id          String       @id @default(uuid())
  nameUz      String
  nameRu      String?
  nameEn      String?
  type        ClinicType   @default(GENERAL)
  status      ClinicStatus @default(PENDING)
  description String?      @db.Text
  logo        String?
  coverImage  String?

  // Location
  region    String
  district  String
  street    String
  apartment String?
  landmark  String?
  latitude  Float?
  longitude Float?

  // Contact
  phones      Json    @default("[]")
  emails      Json    @default("[]")
  website     String?
  socialMedia Json?

  // Schedule
  workingHours     Json    @default("[]")
  hasEmergency     Boolean @default(false)
  hasAmbulance     Boolean @default(false)
  hasOnlineBooking Boolean @default(true)

  // Infrastructure
  bedsCount        Int?
  floorsCount      Int?
  parkingAvailable Boolean @default(false)
  amenities        Json?

  // Payment
  paymentMethods    Json?
  insuranceAccepted Json?
  priceRange        String?

  // Ratings
  averageRating Float? @default(0)
  reviewCount   Int    @default(0)

  // Source tracking
  source      ClinicSource @default(ADMIN_CREATED)
  createdBy   String?      // Super Admin ID (ADMIN_CREATED)
  submittedAt DateTime?    // When self-registration was submitted
  reviewedAt  DateTime?    // When approved/rejected
  reviewedBy  String?      // Admin user ID who reviewed

  // Documents
  registrationNumber String?
  taxId              String?
  licenseNumber      String?
  licenseIssuedAt    DateTime?
  licenseExpiresAt   DateTime?
  licenseIssuedBy    String?

  // Admin contact
  adminFirstName String?
  adminLastName  String?
  adminEmail     String?
  adminPhone     String?
  adminPosition  String?

  // Persons data (stored until approval for SELF_REGISTERED)
  pendingPersons Json?

  // Moderation
  rejectionReason String?
  notes           String? @db.Text
  approvedById    String?

  doctors            Doctor[]
  appointments       Appointment[]
  reviews            Review[]
  diagnosticServices ClinicDiagnosticService[]
  surgicalServices   ClinicSurgicalService[]
  checkupPackages    ClinicCheckupPackage[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@index([region])
  @@index([type])
  @@index([createdAt])
}

model Doctor {
  id        String   @id @default(uuid())
  clinicId  String
  firstName String
  lastName  String
  specialty String?
  bio       String?  @db.Text
  photoUrl  String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]

  @@index([clinicId])
  @@index([isActive])
}

model Appointment {
  id                  String                 @id @default(uuid())
  clinicId            String
  patientId           String
  doctorId            String?
  serviceType         AppointmentServiceType @default(OTHER)
  diagnosticServiceId String?
  surgicalServiceId   String?
  scheduledAt         DateTime
  status              AppointmentStatus      @default(PENDING)
  price               Int                    @default(0)
  notes               String?                @db.Text
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  patient User    @relation(fields: [patientId], references: [id])
  doctor  Doctor? @relation(fields: [doctorId], references: [id])

  diagnosticService DiagnosticService? @relation("DiagnosticServiceAppointments", fields: [diagnosticServiceId], references: [id])
  surgicalService   SurgicalService?   @relation("SurgicalServiceAppointments", fields: [surgicalServiceId], references: [id])

  @@index([clinicId])
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([scheduledAt])
}

model Review {
  id        String   @id @default(uuid())
  clinicId  String
  userId    String
  rating    Float
  comment   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([clinicId, userId])
  @@index([clinicId])
  @@index([userId])
  @@index([rating])
  @@index([isActive])
}

model ClinicDiagnosticService {
  id                  String   @id @default(uuid())
  clinicId            String
  diagnosticServiceId String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  clinic            Clinic            @relation(fields: [clinicId], references: [id])
  diagnosticService DiagnosticService @relation("DiagnosticServiceClinicLinks", fields: [diagnosticServiceId], references: [id])
  customization     ServiceCustomization?

  @@unique([clinicId, diagnosticServiceId])
  @@index([clinicId])
  @@index([diagnosticServiceId])
  @@index([isActive])
}

// ─── SERVICE CUSTOMIZATION ──────────────────────────────────────────────────
model ServiceCustomization {
  id                       String   @id @default(uuid())
  clinicServiceId          String   @unique

  // Custom naming (optional — falls back to DiagnosticService fields if null)
  customNameUz             String?
  customNameRu             String?

  // Custom descriptions
  customDescriptionUz      String?  @db.Text
  customDescriptionRu      String?  @db.Text

  // Benefits / features (JSONB array)
  benefits                 Json?

  // Preparation instructions (clinic-specific)
  preparationUz            String?  @db.Text
  preparationRu            String?  @db.Text

  // Custom category / tags
  customCategory           String?
  tags                     String[]

  // Duration & scheduling
  estimatedDurationMinutes Int?
  availableDays            String[]
  availableTimeSlots       Json?

  // Booking requirements
  requiresAppointment      Boolean  @default(true)
  requiresPrepayment       Boolean  @default(false)
  prepaymentPercentage     Int?

  // Display metadata
  isHighlighted            Boolean  @default(false)
  displayOrder             Int?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  clinicService            ClinicDiagnosticService @relation(fields: [clinicServiceId], references: [id], onDelete: Cascade)
  images                   ServiceImage[]

  @@index([clinicServiceId])
  @@index([customCategory])
  @@index([isHighlighted])
  @@index([displayOrder])
}

// ─── SERVICE IMAGES ─────────────────────────────────────────────────────────
model ServiceImage {
  id              String   @id @default(uuid())
  customizationId String

  url             String
  alt             String?
  order           Int      @default(0)
  isPrimary       Boolean  @default(false)

  uploadedAt      DateTime @default(now())

  customization   ServiceCustomization @relation(fields: [customizationId], references: [id], onDelete: Cascade)

  @@index([customizationId])
  @@index([order])
  @@index([isPrimary])
}

model ClinicSurgicalService {
  clinicId          String
  surgicalServiceId String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  clinic          Clinic          @relation(fields: [clinicId], references: [id])
  surgicalService SurgicalService @relation("SurgicalServiceClinicLinks", fields: [surgicalServiceId], references: [id])

  @@id([clinicId, surgicalServiceId])
  @@index([clinicId])
  @@index([surgicalServiceId])
  @@index([isActive])
}

// ─── CHECKUP PACKAGES ────────────────────────────────────────────────────────
model CheckupPackage {
  id                String   @id @default(cuid())
  
  // Names (multi-language)
  nameUz            String
  nameRu            String?
  nameEn            String?
  slug              String   @unique
  
  // Category
  category          CheckupCategory
  
  // Descriptions
  shortDescription  String?  @db.VarChar(200)
  fullDescription   String?  @db.Text
  
  // Target audience
  targetAudience    String?  @db.VarChar(100)
  
  // Pricing
  recommendedPrice  Int      // UZS
  priceMin          Int      // Min for clinics
  priceMax          Int      // Max for clinics
  discount          Int?     // Discount amount vs individual prices
  
  // Media
  imageUrl          String?
  
  // Status
  isActive          Boolean  @default(true)
  
  // Relations
  items             CheckupPackageItem[]
  clinicPackages    ClinicCheckupPackage[]
  
  // Metadata
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([category])
  @@index([isActive])
  @@index([slug])
}

model CheckupPackageItem {
  id                  String   @id @default(cuid())
  
  packageId           String
  package             CheckupPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  // Reference to diagnostic service
  diagnosticServiceId String
  
  // Cached data (denormalized for performance)
  serviceName         String   // From DiagnosticService.nameUz
  servicePrice        Int      // From DiagnosticService.priceRecommended
  
  // Package-specific
  quantity            Int      @default(1)
  isRequired          Boolean  @default(true)
  notes               String?  @db.VarChar(255)
  
  // Order
  sortOrder           Int      @default(0)
  
  @@index([packageId])
  @@index([diagnosticServiceId])
}

model ClinicCheckupPackage {
  id              String   @id @default(cuid())
  
  clinicId        String
  clinic          Clinic         @relation(fields: [clinicId], references: [id])
  packageId       String
  package         CheckupPackage @relation(fields: [packageId], references: [id])
  
  // Clinic's custom data
  clinicPrice     Int      // Must be between priceMin and priceMax
  customNotes     String?  @db.Text
  
  // Status
  isActive        Boolean  @default(true)
  
  // Stats
  bookingCount    Int      @default(0)
  
  // Metadata
  activatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([clinicId, packageId])
  @@index([clinicId])
  @@index([packageId])
  @@index([isActive])
}

enum CheckupCategory {
  BASIC          // Bazaviy (umumiy)
  SPECIALIZED    // Ixtisoslashgan (kardio, gastro, etc.)
  AGE_BASED      // Yosh guruhi (40+, ayollar, etc.)
}

enum RegistrationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

model ClinicRegistrationRequest {
  id     String             @id @default(uuid())
  status RegistrationStatus @default(PENDING)

  // Step 1 - Basic info
  nameUz        String
  nameRu        String?
  nameEn        String?
  clinicType    String
  foundedYear   Int?
  descriptionUz String   @db.Text
  descriptionRu String?  @db.Text
  logoUrl       String?

  // Step 2 - Location
  regionId      String
  districtId    String
  streetAddress String
  addressUz     String
  addressRu     String?
  zipCode       String?
  googleMapsUrl String?
  landmark      String?
  latitude      Float?
  longitude     Float?

  // Step 3 - Contacts
  primaryPhone   String
  secondaryPhone String?
  emergencyPhone String?
  email          String
  website        String?
  telegram       String?
  instagram      String?
  facebook       String?
  youtube        String?

  // Step 4 - Working hours (JSON)
  workingHours    Json
  isAlwaysOpen    Boolean @default(false)
  lunchBreakStart String?
  lunchBreakEnd   String?
  holidayNotes    String? @db.Text

  // Step 5 - Services
  selectedServices Json @default("[]")

  // Step 6 - Admin persons (array)
  persons      ClinicRegistrationPerson[]

  // Step 7 - Documents
  licenseUrl    String?
  licenseNumber String
  licenseExpiry String
  inn           String
  legalName     String
  legalAddress  String
  legalForm     String?
  certificates  Json    @default("[]")

  // Step 8 - Payment
  bankName          String
  bankAccountNumber String
  mfo               String
  oked              String?
  vatNumber         String?
  paymentMethods    Json   @default("[]")
  invoiceEmail      String?

  // Moderation
  rejectionReason String? @db.Text
  reviewedById    String?
  reviewedAt      DateTime?
  notes           String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ClinicRegistrationPerson {
  id            String                   @id @default(uuid())
  requestId     String
  request       ClinicRegistrationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  firstName    String
  lastName     String
  middleName   String?
  position     String
  phone        String
  email        String?
  passwordHash String
  isPrimary    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([phone])
}
