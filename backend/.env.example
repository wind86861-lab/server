NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/banisa_db?schema=public

# Legacy secret — kept for backward compat, prefer the two below
JWT_SECRET=super-secret-key-change-me-in-production
JWT_EXPIRES_IN=7d

# VULN-03: separate access/refresh secrets — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_64_char_hex_for_access_token
JWT_REFRESH_SECRET=generate_different_64_char_hex_for_refresh_token

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CORS_ORIGIN=http://localhost:3000
